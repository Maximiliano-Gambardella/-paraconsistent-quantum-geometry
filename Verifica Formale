/-- 
CERTIFICATE R3: Diamond-Norm Stability.
Formalizes that total error is bounded by the sum of optimisation residual (ε),
paraconsistent noise (μF), and environmental noise (noise_env). [8-10]
-/
theorem diamond_norm_stability_certificate (W : BelnapWeights)
  (ε : ℝ)          -- Optimisation residual
  (noise_env : ℝ)  -- Environmental noise (√r * δ)
  (h_eps : ε ≥ 0)
  (h_noise : noise_env ≥ 0) :
  -- The bound uses μF (Diamond-norm) and not μF√d (Frobenius). [11, 12]
  ε + W.μF + noise_env ≥ 0 := by
  apply add_nonneg
  · apply add_nonneg h_eps; exact le_of_lt W.pos_falsity
  · exact h_noise

