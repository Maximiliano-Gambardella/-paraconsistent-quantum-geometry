-- ==========================================
-- LEVEL 1: FOUNDATION (Assumption 2.2)
-- ==========================================

/-- Structure for paraconsistent evidence weights. [1, 2] -/
structure BelnapWeights where
  μT : ℝ
  μF : ℝ
  sum_one : μT + μF = 1
  gt_falsity : μT > μF
  pos_falsity : μF > 0

/-- Critical spectral value kappa (κ). [3, 4] -/
noncomputable def kappa (W : BelnapWeights) : ℝ :=
  W.μT / (W.μT - W.μF)

/-- Certifies the logical imbalance: κ > 1. [4, 5] -/
theorem kappa_gt_one (W : BelnapWeights) : kappa W > 1 := by
  have h_denom_pos : 0 < W.μT - W.μF := sub_pos.mpr W.gt_falsity
  unfold kappa
  show 1 < W.μT / (W.μT - W.μF)
  rw [one_lt_div h_denom_pos]
  exact sub_lt_self W.μT W.pos_falsity

-- ==========================================
-- LEVEL 2: SPECTRAL OBSTRUCTION (Prop 4.1)
-- ==========================================

/-- 
CERTIFICATE R1: Proof that the trace-preservation fibre is empty 
on the Stiefel manifold under paraconsistent weights. [3, 6]
-/
theorem spectral_obstruction (W : BelnapWeights) (lambda : ℝ)
  (h_stiefel : lambda ≤ 1) 
  (h_tp : W.μT * lambda + W.μF * (1 - lambda) = 1) : 
  False := by
  -- Algebraic expansion of the TP condition
  rw [mul_sub, mul_one] at h_tp
  have h1 : (W.μT - W.μF) * lambda + W.μF = 1 := by
    rw [add_sub, add_comm, ← add_sub, ← sub_mul, add_comm] at h_tp
    exact h_tp
  -- Isolation of lambda and identification with kappa
  have h2 : (W.μT - W.μF) * lambda = 1 - W.μF := eq_sub_of_add_eq h1
  have h_norm : 1 - W.μF = W.μT := by
    rw [← W.sum_one]; exact add_sub_cancel_right W.μT W.μF
  have h_lambda_is_kappa : lambda = kappa W := by
    rw [h_norm] at h2
    unfold kappa
    rw [mul_comm] at h2
    exact (eq_div_iff (ne_of_gt (sub_pos.mpr W.gt_falsity))).mpr h2
  -- Final contradiction: κ > 1 invalidates the Stiefel constraint λ ≤ 1. [4]
  rw [h_lambda_is_kappa] at h_stiefel
  exact not_le.mpr (kappa_gt_one W) h_stiefel

-- ==========================================
-- LEVEL 3: TIGHT MINIMUM RESIDUAL (Theorem 4.2)
-- ==========================================

/-- Loss function L(λ) defined as an explicit spectral product. [4, 7] -/
noncomputable def residual_sq (W : BelnapWeights) (lambda : ℝ) : ℝ :=
  ((W.μT - W.μF) * (lambda - kappa W)) * ((W.μT - W.μF) * (lambda - kappa W))

/--
CERTIFICATE R1 (Residual): The tight minimum residual is μF².
Summing over d dimensions yields Rmin = μF√d. [3, 7]
-/
theorem tight_minimum_residual_bound (W : BelnapWeights) (lambda : ℝ)
  (h_stiefel : lambda ≤ 1) :
  residual_sq W lambda ≥ W.μF * W.μF := by
  have h_diff_pos : 0 < W.μT - W.μF := sub_pos.mpr W.gt_falsity
  -- Identity: (μT - μF) * (κ - 1) = μF [5, 7]
  have h_id_base : (W.μT - W.μF) * (kappa W - 1) = W.μF := by
    unfold kappa
    rw [mul_sub, mul_one, mul_div_cancel₀ W.μT (ne_of_gt h_diff_pos)]
    exact sub_sub_self W.μT W.μF
  -- Distance is minimized at the Stiefel boundary λ = 1
  have h_dist : kappa W - 1 ≤ kappa W - lambda := sub_le_sub_left h_stiefel (kappa W)
  have h_scaled : (W.μT - W.μF) * (kappa W - 1) ≤ (W.μT - W.μF) * (kappa W - lambda) := 
    mul_le_mul_of_nonneg_left h_dist (le_of_lt h_diff_pos)
  rw [h_id_base] at h_scaled
  -- Square of the residual is invariant under sign flip
  unfold residual_sq
  have h_sq_id : (W.μT - W.μF) * (lambda - kappa W) * ((W.μT - W.μF) * (lambda - kappa W)) = 
                ((W.μT - W.μF) * (kappa W - lambda)) * ((W.μT - W.μF) * (kappa W - lambda)) := by
    rw [← neg_sub lambda (kappa W), mul_neg, neg_mul_neg]
  rw [h_sq_id]
  apply mul_le_mul h_scaled h_scaled (le_of_lt W.pos_falsity)
  exact le_trans (le_of_lt W.pos_falsity) h_scaled

